{
  "name": "vellum",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "wrangler d1 migrations apply vellum-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply vellum-db --remote",
    "deploy": "vite build && wrangler deploy"
  },
