    "@cloudflare/workers-types": "^4.20250610.0",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.1.8",
    "@tanstack/router-plugin": "^1.168.18",
    "@types/react": "^19.1.6",
